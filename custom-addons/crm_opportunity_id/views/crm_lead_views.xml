<odoo>
  <record id="view_crm_lead_form_custom" model="ir.ui.view">
    <field name="name">crm.lead.form.custom</field>
    <field name="model">crm.lead</field>
    <field name="inherit_id" ref="crm.crm_lead_view_form"/>
    <field name="arch" type="xml">

      <!-- Botão no button_box -->
     <xpath expr="//div[@name='button_box']" position="inside">
      <button
          name="action_open_qr_scanner"
          type="object"
          class="oe_stat_button"
          icon="fa-qrcode">
            <div class="o_stat_info">
              <span class="o_stat_text">Lançar Despesa via QRCode</span>
            </div>
      </button>
    </xpath>


      <!-- Bloco antes do campo name -->
      <field name="name" position="before">
        <div class="oe_title">
          <h2>
            <field name="oportunidade_id" readonly="1"/>
          </h2>
        </div>
      </field>

      <!-- Percentagem depois do campo probability, em grid -->
 <xpath expr="//field[@name='name']" position="after">
  <group>
    <div class="d-flex align-items-center flex-wrap mt-2">
      <div class="d-flex align-items-center me-4">
        <span class="fw-bold text-dark me-2">Execução</span>
        <field name="execution_percentage" widget="percentage" class="oe_inline"/>
      </div>

      <div class="d-flex align-items-center me-4">
        <span class="fw-bold text-dark me-2">Faturação</span>
        <field name="billing_percentage" widget="percentage" class="oe_inline"/>
      </div>

      <div class="d-flex align-items-center">
        <span class="fw-bold text-dark me-2">Recebimento</span>
        <field name="receipt_percent" widget="percentage" class="oe_inline"/>
      </div>
    </div>
  </group>
</xpath>
  </field>
  </record>
   <record id="view_crm_lead_tree_inherit_receipt" model="ir.ui.view">
        <field name="name">crm.lead.tree.receipt.percentage</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='expected_revenue']" position="after">
                <field name="execution_percentage"/>
            </xpath>
             <xpath expr="//field[@name='execution_percentage']" position="after">
                <field name="billing_percentage"/>
            </xpath>
             <xpath expr="//field[@name='billing_percentage']" position="after">
                <field name="receipt_percent"/>
            </xpath>
        </field>
    </record>
</odoo>
