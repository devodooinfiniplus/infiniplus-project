<odoo>
  <record id="fsm_location_form_optional_owner" model="ir.ui.view">
    <field name="name">fsm.location.form.optional.owner</field>
    <field name="model">fsm.location</field>
    <field name="inherit_id" ref="fieldservice.fsm_location_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='owner_id']" position="attributes">
        <attribute name="required">0</attribute>
      </xpath>
      <xpath expr="//field[@name='partner_id']" position="attributes">
        <attribute name="required">0</attribute>
      </xpath>
    </field>
  </record>
</odoo>
