<odoo>
  <record id="view_move_form_inherit_lead_display" model="ir.ui.view">
    <field name="name">account.move.form.inherit.lead.display</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
      <xpath expr="//div[@class='oe_title']/h1" position="after">

        <button name="action_open_opportunity"
                type="object"
                class="btn btn-link text-start fs-1 m-0 p-0 d-block"
                invisible="crm_opportunity_id == False">
          <field name="sale_lead_oppotunity_display" readonly="1"/>
        </button>

        <button name="action_open_fieldservice_location"
                type="object"
                class="btn btn-link text-start fs-1 m-0 p-0 d-block"
                invisible="crm_fieldservice_location == False">
          <field name="crm_fieldservice_location_name" readonly="1"/>
        </button>

      </xpath>
    </field>
  </record>
</odoo>
