
<odoo>
    <record id="hr_expense_form_qr" model="ir.ui.view">
        <field name="name">hr.expense.form.qr</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <button name="action_open_qr_scanner"
                        type="object"
                        string="Guardar fatura via QR Code"
                        class="btn btn-secondary"/>
            </xpath>

            <xpath expr="//sheet/group" position="inside">
                <field name="qr_raw_string" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
