<odoo>
    <record id="view_qr_invoice_reader_wizard_form" model="ir.ui.view">
        <field name="name">qr.invoice.reader.wizard.form</field>
        <field name="model">qr.invoice.reader.wizard</field>
        <field name="arch" type="xml">
            <form string="Ler QR Code AT">
                <group>
                    <field name="qr_data" readonly="1"/>
                    <div id="qr-reader" style="width:100%;"/>
                </group>
                <footer>
                    <button name="action_process_qr"
                            type="object"
                            string="Guardar Fatura"
                            class="btn-primary"
                         />
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
